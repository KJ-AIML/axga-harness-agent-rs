# Maintainer: AXGA Contributors
# Contributor: KJ-AIML

pkgname=axga
pkgver=0.1.0
pkgrel=1
pkgdesc="5.7MB AI coding agent — runs on 1GB VPS (10 tools, 3 providers, TUI + Telegram)"
arch=('x86_64' 'aarch64')
url="https://github.com/KJ-AIML/axga-harness-agent-rs"
license=('MIT')

_platform() {
  case "$CARCH" in
    x86_64)  echo "x86_64-unknown-linux-musl" ;;
    aarch64) echo "aarch64-unknown-linux-musl" ;;
    *)       echo "unsupported"; return 1 ;;
  esac
}

source=("$url/releases/download/v$pkgver/axga-v$pkgver-$(_platform).tar.gz")
sha256sums=('REPLACE_WITH_ACTUAL_SHA256')

package() {
  install -Dm755 "$srcdir/axga" "$pkgdir/usr/bin/axga"
}
